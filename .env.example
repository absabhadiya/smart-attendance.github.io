PORT=3000
NODE_ENV=development

# Database Configuration
# Local Connection (Uncomment for local work)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=attendance_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# Cloud Connection (Recommended for Persistence)
# Get this from Supabase Dashboard > Project Settings > Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres

# Auth
JWT_SECRET=super_secret_jwt_key_2024

# Email (Nodemailer)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Vision Module
# Windows absolute path example: C:/Users/mypc/anaconda3/envs/attendance_env/python.exe
PYTHON_PATH=python
